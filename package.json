{
  "name": "four-in-one-customer-service",
  "version": "1.2.0",
  "description": "千帆客服台机器人：买家消息微信通知 + 二号引用回复千帆",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "node scripts/prebuild-kill-packaged-app.js && electron-builder --win dir --publish never",
    "build:dir": "node scripts/prebuild-kill-packaged-app.js && electron-builder --win dir --publish never",
    "build:portable": "electron-builder --win portable",
    "build:setup": "electron-builder --win nsis",
    "start:cli": "node src/wxbot-new-oneclick.js",
    "wx:check": "node src/wxbot-new-check.js",
    "wx:callback": "node src/wxbot-new-callback-server.js",
    "wx:test-send": "node src/wxbot-new-test-send.js",
    "test:native-sync-send": "node scripts/test-native-sync-send.js",
    "test:youdao-license": "node scripts/test-youdao-license-check.js",
    "check:packaged-workers": "node scripts/check-packaged-workers.js",
    "check:runtime": "node scripts/check-runtime-architecture.js",
    "check:worker-start-retry": "node scripts/check-worker-start-retry.js",
    "check:qianfan-send-dedup": "node scripts/check-qianfan-send-dedup-gate.js",
    "check:qianfan-send-bridge": "node scripts/check-qianfan-send-bridge-worker.js",
    "check:qianfan-send-retry": "node scripts/check-qianfan-send-retry.js",
    "check:qianfan-impaas-wake": "node scripts/check-qianfan-impaas-ws-wake.js",
    "check:qianfan-cookie-collector": "node scripts/check-qianfan-cookie-collector.js",
    "check:qianfan-cookie-readonly": "node scripts/check-qianfan-cookie-readonly.js",
    "check:qianfan-cookie-sync-api": "node scripts/check-qianfan-cookie-sync-api.js",
    "check:shop-cookie-upload": "node scripts/check-shop-cookie-upload.js",
    "check:qianfan-kill-policy": "node scripts/check-qianfan-kill-policy.js",
    "check:start-idempotent": "node scripts/check-runtime-start-idempotent.js",
    "check:ui-log-dedup": "node scripts/check-ui-log-dedup.js",
    "check:homepage-health": "node scripts/check-homepage-health-status.js",
    "check:qianfan-status": "node scripts/check-qianfan-status-snapshot.js",
    "check:failure-owner": "node scripts/check-failure-receipt-owner.js",
    "check:longrun-stable-invariants": "node scripts/check-longrun-stable-invariants.js",
    "check:workers": "node scripts/check-worker-boundaries.js",
    "check:watchdog": "node scripts/check-watchdog-restart.js",
    "check:bus": "node scripts/check-message-bus-routing.js",
    "check:callback": "node scripts/check-callback-singleton.js",
    "check:failure-receipt": "node scripts/check-failure-receipt-path.js",
    "check:restart-state": "node scripts/check-worker-restart-state.js",
    "check:watchdog-false-positive": "node scripts/check-watchdog-false-positive.js",
    "check:persistence": "node scripts/check-persistence-actions.js",
    "check:idempotency": "node scripts/check-idempotency-keys.js",
    "check:bus-rpc": "node scripts/check-request-response-bus.js",
    "check:state-recovery": "node scripts/check-distributed-state-recovery.js",
    "check:failure-dedup": "node scripts/check-failure-receipt-dedup.js",
    "check:dead-letter": "node scripts/check-dead-letter.js",
    "check:sim-chain": "node scripts/check-live-chain-simulation.js",
    "check:e2e-idempotency": "node scripts/check-end-to-end-idempotency.js",
    "check:chaos-crash": "node scripts/check-chaos-worker-crash.js",
    "check:chaos-crash-fast": "node scripts/check-chaos-worker-crash-fast.js",
    "check:chaos-watchdog": "node scripts/check-chaos-watchdog-timeout.js",
    "check:persistence-timeout": "node scripts/check-persistence-timeout.js",
    "check:cli-compat": "node scripts/check-cli-compatibility.js",
    "check:notifier-hooks": "node scripts/check-notifier-persist-hooks-compat.js",
    "check:longrun-smoke": "node scripts/check-longrun-smoke.js",
    "check:longrun-idempotency": "node scripts/check-longrun-idempotency.js",
    "check:longrun-chaos": "node scripts/check-longrun-chaos.js",
    "check:longrun-leaks": "node scripts/check-longrun-leaks.js",
    "check:longrun-leaks-fast": "node scripts/check-longrun-leaks-fast.js",
    "longrun:smoke": "node scripts/run-longrun-simulation.js --scenario smoke-1day",
    "longrun:stable": "node scripts/run-longrun-simulation.js --scenario stable-100days",
    "longrun:stress": "node scripts/run-longrun-simulation.js --scenario stress-10000days",
    "longrun:million": "node scripts/run-longrun-simulation.js --scenario million-years-fast",
    "check:quick": "npm run check:runtime && npm run check:workers && npm run check:worker-start-retry && npm run check:qianfan-send-dedup && npm run check:qianfan-send-bridge && npm run check:qianfan-send-retry && npm run check:qianfan-impaas-wake && npm run check:qianfan-runtime && npm run check:qianfan-kill-policy && npm run check:start-idempotent && npm run check:ui-log-dedup && npm run check:qianfan-status && npm run check:failure-owner && npm run check:watchdog && npm run check:bus && npm run check:callback && npm run check:failure-receipt && npm run check:restart-state && npm run check:persistence && npm run check:idempotency && npm run check:bus-rpc && npm run check:dead-letter && npm run check:cli-compat && npm run check:notifier-hooks && npm run check:sim-chain && npm run check:qianfan-cookie-readonly && npm run check:qianfan-cookie-sync-api",
    "check:chaos-suite": "npm run check:watchdog-false-positive && npm run check:state-recovery && npm run check:failure-dedup && npm run check:chaos-crash && npm run check:chaos-watchdog && npm run check:persistence-timeout && npm run check:e2e-idempotency",
    "check:longrun-suite": "npm run check:longrun-smoke && npm run check:longrun-idempotency && npm run check:longrun-chaos && npm run check:longrun-leaks",
    "check:full": "npm run check:quick && npm run check:chaos-suite && npm run check:longrun-suite",
    "check:timed": "node scripts/run-checks-with-timing.js",
    "check": "npm run check:quick",
    "qf:protocol:probe": "node scripts/probe-qianfan-protocol.js",
    "qf:protocol:listen": "node scripts/test-qianfan-protocol-listen.js",
    "qf:protocol:list": "node scripts/test-qianfan-protocol-message-list.js",
    "qf:protocol:send-text": "node scripts/test-qianfan-protocol-send-text.js",
    "qf:protocol:send-image": "node scripts/test-qianfan-protocol-send-image.js",
    "qf:protocol:test": "node scripts/run-qianfan-protocol-all-tests.js",
    "qf:protocol:export-live": "node scripts/export-qianfan-live-protocol-context.js",
    "qf:protocol:bootstrap-live": "node scripts/export-qianfan-live-protocol-context.js --write-local --run-probe",
    "qf:protocol:auto": "node scripts/run-qianfan-protocol-auto.js",
    "qf:protocol:tap:status": "node scripts/qianfan-protocol-tap-status.js",
    "qf:protocol:tap:bundle": "node scripts/bundle-qianfan-protocol-tap.js",
    "qf:protocol:tap:auto": "node scripts/run-qianfan-protocol-tap-auto.js",
    "qf:protocol:tap:full": "node scripts/run-qianfan-protocol-tap-full.js",
    "qf:protocol:im": "node scripts/run-qianfan-protocol-im.js",
    "qf:protocol:pure": "node scripts/run-qianfan-protocol-pure.js",
    "qf:protocol:daemon": "node scripts/qianfan-protocol-daemon.js",
    "qf:protocol:bootstrap-tap": "node scripts/bootstrap-protocol-shops-from-tap.js",
    "qf:protocol:triple-reply": "node scripts/bootstrap-protocol-shops-from-tap.js && node scripts/run-qianfan-protocol-triple-auto-reply.js",
    "qf:protocol:config-agent": "node scripts/qianfan-protocol-config-agent.js",
    "qf:protocol:bridge": "node scripts/qianfan-protocol-bridge-server.js",
    "qf:protocol:import-captured": "node scripts/import-xiangyu-captured-to-protocol.js",
    "qf:protocol:xiangyu-qr": "node scripts/generate-xiangyu-server-qr.js",
    "check:qianfan-protocol-daemon": "node scripts/check-qianfan-protocol-daemon.js"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "chrome-remote-interface": "^0.33.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.1.8",
    "qrcode": "^1.5.4"
  },
  "build": {
    "appId": "com.qianfan.customer-service-bot",
    "productName": "千帆客服台机器人",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "启动千帆调试模式.bat",
      "config.wxbot-new.example.json",
      "package.json",
      "!reports/**",
      "!data/**",
      "!logs/**",
      "!scripts/**",
      "!**/*.md",
      "!**/.git*"
    ],
    "extraResources": [
      {
        "from": "tools/wxbot-new-runtime",
        "to": "wxbot-new-runtime",
        "filter": [
          "**/*",
          "!logs/**",
          "!uploads/**"
        ]
      }
    ],
    "extraFiles": [
      {
        "from": "config.wxbot-new.json",
        "to": "config.wxbot-new.json"
      }
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "signDlls": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-便携版.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-安装版.exe"
    }
  }
}
